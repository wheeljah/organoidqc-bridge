# =============================================
# OrganoidQC Bridge — 환경변수 예시
# 클라우드 배포 시 플랫폼 환경변수로 설정하세요
# 로컬 개발 시: cp .env.example .env
# =============================================

# 서버
HOST=0.0.0.0
PORT=8000

# OrganoID 설치 경로 (클라우드: Docker 내 /app/organoID)
ORGANO_ID_DIR=/app/organoID

# 업로드 디렉터리
# 클라우드: /tmp/uploads (컨테이너 재시작 시 초기화)
# 로컬:    ./uploads
UPLOAD_DIR=/tmp/uploads

# 이미지 저장 여부
# 클라우드: false (임시 스토리지)
# 로컬:    true
KEEP_UPLOADS=false
